{%- liquid
  assign images = ''
  assign images = images | append: section.settings.image_1 | append: '||'
  assign images = images | append: section.settings.image_2 | append: '||'
  assign images = images | append: section.settings.image_3 | append: '||'
  assign images = images | append: section.settings.image_4
-%}

{%- style -%}
  #lambo-hero-{{ section.id }} {
    padding-top: {{ section.settings.padding-block-start }}px;
    padding-bottom: {{ section.settings.padding-block-end }}px;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__inner {
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__header {
    text-align: {{ section.settings.alignment }};
    margin-bottom: 2rem;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__heading {
    margin: 0 0 0.5rem;
    {% if section.settings.heading_size != blank %}font-size: {{ section.settings.heading_size }}px;{% endif %}
    line-height: 1.05;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__subheading {
    margin: 0;
    opacity: 0.8;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.corner_radius }}px;
    aspect-ratio: {{ section.settings.image_ratio }};
    background: rgba(0,0,0,0.05);
  }

  #lambo-hero-{{ section.id }} .lambo-hero__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #lambo-hero-{{ section.id }} .lambo-hero__item:hover img {
    transform: scale(1.04);
  }

  @media screen and (max-width: 749px) {
    #lambo-hero-{{ section.id }} .lambo-hero__grid {
      grid-template-columns: {% if section.settings.stack_on_mobile %}1fr{% else %}repeat(2, 1fr){% endif %};
    }
  }
{%- endstyle -%}

<div
  id="lambo-hero-{{ section.id }}"
  class="lambo-hero color-{{ section.settings.color_scheme }}"
>
  <div class="lambo-hero__inner">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="lambo-hero__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="lambo-hero__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="lambo-hero__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lambo-hero__grid">
      {%- assign image_list = images | split: '||' -%}
      {%- for slot in (1..4) -%}
        {%- assign index = forloop.index0 -%}
        {%- assign picked = image_list[index] -%}
        {%- assign default_asset = 'lambo-' | append: slot | append: '.jpg' -%}
        <div class="lambo-hero__item">
          {%- if picked != blank -%}
            {{
              picked
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '400, 600, 800, 1000, 1200, 1600',
                alt: picked.alt | default: 'Lamborghini'
            }}
          {%- else -%}
            <img
              src="{{ default_asset | asset_url }}"
              alt="Lamborghini Aventador"
              loading="lazy"
              width="1600"
              height="1067"
            >
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lambo hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Raging Bulls"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Four shades of Aventador."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "paragraph",
      "content": "Leave a slot empty to use the default Lamborghini image for that position."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "16 / 9", "label": "Landscape (16:9)" },
        { "value": "3 / 2", "label": "Landscape (3:2)" },
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" }
      ],
      "default": "3 / 2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "stack_on_mobile",
      "label": "Stack images in one column on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Lambo hero"
    }
  ]
}
{% endschema %}
